{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "target": "es2022",
    "sourceMap": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "strict": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "./src/**/*.ts",
    "package.json",
    "drizzle.config.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
