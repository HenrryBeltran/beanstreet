{
  "compilerOptions": {
    // base options 
    "esModuleInterop": true,
    "skipLibCheck": true,
    "target": "es2022",
    "verbatimModuleSyntax": true,
    "allowJs": true,
    "resolveJsonModule": true,
    "moduleDetection": "force",
    // Strictness
    "strict": true,
    "noUncheckedIndexedAccess": true,
    // Transpiling
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "outDir": "dist",
    "sourceMap": true,
    //
    // "allowImportingTsExtensions": true,
    // "noEmit": true,
  },
  "include": [
    "./src/**/*.ts",
    "package.json",
    "drizzle.config.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
